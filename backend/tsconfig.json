{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*", "seed.ts", "drizzle.config.ts"]
}
